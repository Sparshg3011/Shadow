# Deadbolt — environment template. Copy to deadbolt/.env and fill in.
# deadbolt/.env is gitignored; never commit real keys.

# --- Orchestrator (Fetch.ai uAgents, REST on :8000) ---
# ASI:One LLM key — required for real intent classification. https://asi1.ai/developer
# Without it the orchestrator still runs; intents just fall back to "unknown".
ASI_ONE_API_KEY=
# Deterministic seed -> fixes the orchestrator's Agentverse address/identity.
AGENT_SEED=shadow-orchestrator
# REST + mailbox port (the dashboard proxies /api -> here).
PORT=8000
# Seconds to wait for a downstream agent's reply before timing out.
DOWNSTREAM_TIMEOUT=45
# Set false for local dashboard dev to skip the Agentverse mailbox handshake.
AGENT_MAILBOX=true

# --- Agentverse marketplace ---
# Search is public (no key). A token unlocks resolve/manifest + higher rate limits.
# av-scoped bearer token from https://agentverse.ai (Developer settings).
AGENTVERSE_API_KEY=

# --- Downstream Amazon search agent (:8001) ---
# Reliable product-links agent. Uses ANTHROPIC_API_KEY (Claude web search).
ANTHROPIC_API_KEY=
SEARCH_PROVIDER=anthropic
SEARCH_AGENT_SEED=shadow-amazon-search
SEARCH_AGENT_PORT=8001
# Default downstream Amazon agent on Agentverse.
AMAZON_AGENT_ADDRESS=agent1qg3gqlzxxcdvtmkx5fr4grlnuct4f43cvp9xgm2z2kg48g2rrn4aq98y6uz
