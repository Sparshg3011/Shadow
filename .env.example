# ASI:One LLM API key (create one at https://asi1.ai/developer)
ASI_ONE_API_KEY=INSERT_YOUR_API_KEY_HERE

# Deterministic seed phrase -> fixes the orchestrator's agent address/identity.
# Use the same seed as your marketplace agent (@shadow-orches) to keep its address.
AGENT_SEED=shadow-orchestrator

# Address of the downstream Amazon grocery agent on Agentverse.
AMAZON_AGENT_ADDRESS=agent1qg3gqlzxxcdvtmkx5fr4grlnuct4f43cvp9xgm2z2kg48g2rrn4aq98y6uz

# Address of the downstream restaurant reservation agent on Agentverse.
# Leave blank to auto-discover (only needed when running the agent remotely).
RESTAURANT_AGENT_ADDRESS=

# Local HTTP port for the orchestrator (REST endpoints + mailbox).
PORT=8000

# Seconds to wait for the downstream agent's reply before timing out.
DOWNSTREAM_TIMEOUT=45

# ── Restaurant reservation agent ──────────────────────────────────────────────
# Foursquare Places API key — create one at https://foursquare.com/developers/
FOURSQUARE_API_KEY=INSERT_YOUR_FOURSQUARE_API_KEY_HERE

# Local HTTP port for the restaurant agent process.
RESTAURANT_AGENT_PORT=8002

# Deterministic seed for the restaurant agent's identity.
RESTAURANT_AGENT_SEED=shadow-restaurant-search-secret-seed-change-me
