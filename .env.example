# Shadow — environment template. Copy to .env and fill in your keys.
# .env is gitignored; never commit real keys.

# Claude — planner/generation model. Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# UI-TARS visual grounding via OpenRouter. Get a key at https://openrouter.ai
# Add a few dollars of credit — UI-TARS is a paid model (~$0.05-0.30 per demo).
OPENROUTER_API_KEY=

# Deepgram voice (Nova-3 speech-to-text + Aura-2 text-to-speech). Get a key at
# https://console.deepgram.com — a Member-or-higher key also enables ephemeral
# tokens; a lower-tier key still works (used directly on this machine).
DEEPGRAM_API_KEY=

# Engine: "native" = Anthropic computer-use (one call/step, fast, default);
#         "agent-s" = Simular Agent-S (needs OPENROUTER_API_KEY for grounding).
SHADOW_ENGINE=native

# Native-engine thinking/spend dial: low | medium | high | max. Lower = faster.
# "low" is Anthropic's recommended setting for snappy computer-use loops.
SHADOW_EFFORT=low
# Native-engine knobs: screenshot long-edge cap and how many recent screenshots to
# keep in context. Anthropic recommends ~1280 (WXGA) for computer-use — 2-3x fewer
# image tokens per step AND more accurate than full-res. Raise only if text is
# unreadable. (The loop prompt-caches the trajectory, so per-step cost stays low.)
SHADOW_DISPLAY_MAX=1280
SHADOW_KEEP_IMAGES=4
# Wheel clicks per unit of the model's scroll amount. Lower if it overshoots buttons.
SHADOW_SCROLL_SCALE=5

# Computer-use model. Sonnet 4.6 is the speed/accuracy sweet spot (~2x faster and
# cheaper than Opus, supports vision + effort). Switch to claude-opus-4-8 for the
# hardest multi-step desktop tasks. NOTE: Haiku 4.5 is NOT supported here — it
# rejects the effort/adaptive-thinking params this engine uses.
SHADOW_GEN_MODEL=claude-sonnet-4-6
# Sunny's conversational replies + task routing — speed matters more than raw power.
SHADOW_CHAT_MODEL=claude-sonnet-4-6
SHADOW_GROUND_MODEL=bytedance/ui-tars-1.5-7b

# Final verification: judge approved/rejected from the end screen. 0 to disable.
SHADOW_VERIFY=1

# Agent loop tuning.
SHADOW_MAX_TRAJECTORY=15
SHADOW_ACTION_DELAY=0.4
# Agent-S only: reflection adds an LLM call per step (slower). 1 to enable.
SHADOW_REFLECTION=0

# Instruction endpoint for middleware (POST /instructions).
SHADOW_HTTP_HOST=127.0.0.1
SHADOW_HTTP_PORT=8765
# Set a token to require `Authorization: Bearer <token>` (recommended if not localhost).
SHADOW_HTTP_TOKEN=

# NOTE: the Deadbolt orchestrator + dashboard are a separate, decoupled stack —
# see deadbolt/.env.example and deadbolt/README.md (not part of the Electron app).
