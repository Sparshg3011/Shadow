# ASI:One LLM API key (create one at https://asi1.ai/developer)
ASI_ONE_API_KEY=INSERT_YOUR_API_KEY_HERE

# Deterministic seed phrase -> fixes the orchestrator's agent address/identity.
# Use the same seed as your marketplace agent (@shadow-orches) to keep its address.
AGENT_SEED=shadow-orchestrator

# Address of the downstream Amazon grocery agent on Agentverse.
AMAZON_AGENT_ADDRESS=agent1qg3gqlzxxcdvtmkx5fr4grlnuct4f43cvp9xgm2z2kg48g2rrn4aq98y6uz

# Local HTTP port for the agent (REST endpoints + mailbox).
PORT=8000

# Seconds to wait for the downstream agent's reply before timing out.
DOWNSTREAM_TIMEOUT=45
